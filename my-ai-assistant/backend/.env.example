# 智谱AI配置
ZHIPUAI_API_KEY=your_zhipuai_api_key_here

# 应用配置
APP_NAME=My AI Assistant
APP_VERSION=1.0.0

# 数据库配置
DATABASE_URL=sqlite:///./database/assistant.db
CHROMA_PERSIST_DIR=./database/chroma

# 服务器配置
HOST=0.0.0.0
PORT=8000
RELOAD=True

# CORS配置（开发环境）
FRONTEND_URL=http://localhost:5173

# 生产环境（部署到Render后，在Render环境变量中设置为你的Vercel前端URL）
# 例如: FRONTEND_URL=https://your-app.vercel.app
